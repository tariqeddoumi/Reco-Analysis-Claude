# Database (Supabase PostgreSQL)
DATABASE_URL="postgresql://postgres.YOURPROJECT:PASSWORD@aws-0-REGION.pooler.supabase.com:6543/postgres?pgbouncer=true"
DIRECT_URL="postgresql://postgres.YOURPROJECT:PASSWORD@aws-0-REGION.pooler.supabase.com:5432/postgres"

# Supabase
NEXT_PUBLIC_SUPABASE_URL="https://YOURPROJECT.supabase.co"
NEXT_PUBLIC_SUPABASE_ANON_KEY="your-anon-key"
SUPABASE_SERVICE_ROLE_KEY="your-service-role-key"

# App
NEXT_PUBLIC_APP_URL="https://yourapp.vercel.app"
NEXT_PUBLIC_APP_NAME="Suivi Recommandations"
